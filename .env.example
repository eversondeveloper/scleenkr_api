# ============================================================
# $cleenkr API — variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA versione o arquivo .env real.
# ============================================================

# --- Banco de dados (PostgreSQL) ---
DB_USER="postgres"
DB_HOST="db"           # "db" dentro do Docker; "localhost" fora dele
DB_NAME="scleenkr"
DB_PASSWORD="sua_senha_aqui"
DB_PORT="5432"

# --- Servidor ---
PORT="3000"

# --- Ambiente ---
NODE_ENV="development"  # development | production

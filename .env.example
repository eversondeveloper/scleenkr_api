# ============================================================
# $cleenkr API — variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA versione o arquivo .env real.
# ============================================================

# --- Banco de dados (PostgreSQL) ---
DB_USER="postgres"
DB_HOST="db"           # "db" dentro do Docker; "localhost" fora dele
DB_NAME="scleenkr"
DB_PASSWORD="sua_senha_aqui"
DB_PORT="5432"

# --- Servidor ---
PORT="3000"

# --- Ambiente ---
NODE_ENV="development"  # development | production

# --- Segurança ---
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque_por_uma_string_longa_e_aleatoria"

# CORS: origens permitidas separadas por vírgula
# Exemplo produção: "https://seudominio.com,https://app.seudominio.com"
CORS_ORIGIN="http://localhost:5173"
